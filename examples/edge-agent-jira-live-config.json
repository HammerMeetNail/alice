    "client_type": "edge_agent"
  },
  "server": {
    "base_url": "http://127.0.0.1:8080"
  },
  "connectors": {
    "jira": {
      "enabled": true,
      "api_base_url": "https://your-domain.atlassian.net",
      "token_env_var": "ALICE_JIRA_TOKEN",
      "projects": [
        {
          "key": "PAY",
          "project_refs": [
            "payments-api"
          ]
        }
      ]
    }
  },
  "runtime": {
    "state_file": "../.alice/edge-agent-jira-live-state.json",
    "query_watch_ids": [],
    "poll_incoming_requests": true
  }
}
