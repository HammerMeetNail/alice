{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alice.local/schemas/query.json",
  "title": "Query",
  "type": "object",
  "required": [
    "to_user_email",
    "purpose",
    "question",
    "requested_types",
    "time_window"
  ],
  "properties": {
    "to_user_email": {
      "type": "string",
      "format": "email"
    },
    "purpose": {
      "type": "string",
      "enum": ["status_check", "dependency_check", "handoff", "manager_update", "request_context"]
    },
    "question": {
      "type": "string",
      "minLength": 1
    },
    "requested_types": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["summary", "commitment", "blocker", "status_delta", "request"]
      }
    },
    "project_scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "time_window": {
      "type": "object",
      "required": ["start", "end"],
      "properties": {
        "start": { "type": "string", "format": "date-time" },
        "end": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
