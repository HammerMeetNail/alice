{
  "agent": {
    "org_slug": "example-corp",
    "owner_email": "jane@example.com",
    "agent_name": "jane-agent",
    "client_type": "edge_agent"
  },
  "server": {
    "base_url": "http://127.0.0.1:8080"
  },
  "connectors": {
    "jira": {
      "enabled": true,
      "api_base_url": "https://your-domain.atlassian.net",
      "projects": [
        {
          "key": "PAY",
          "project_refs": [
            "payments-api"
          ]
        }
      ],
      "oauth": {
        "enabled": true,
        "client_id": "your-atlassian-oauth-client-id",
        "client_secret_env_var": "ALICE_JIRA_CLIENT_SECRET",
        "callback_url": "http://127.0.0.1:8787/oauth/jira/callback"
      }
    }
  },
  "runtime": {
    "state_file": "../.alice/edge-agent-jira-oauth-state.json",
    "credentials_file": "../.alice/edge-agent-jira-credentials.json",
    "query_watch_ids": [],
    "poll_incoming_requests": true
  }
}
