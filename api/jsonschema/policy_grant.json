{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alice.local/schemas/policy_grant.json",
  "title": "PolicyGrant",
  "type": "object",
  "required": [
    "grantee_user_email",
    "scope_type",
    "scope_ref",
    "allowed_artifact_types",
    "max_sensitivity",
    "allowed_purposes"
  ],
  "properties": {
    "grantee_user_email": {
      "type": "string",
      "format": "email"
    },
    "scope_type": {
      "type": "string",
      "minLength": 1
    },
    "scope_ref": {
      "type": "string",
      "minLength": 1
    },
    "allowed_artifact_types": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["summary", "commitment", "blocker", "status_delta", "request"]
      }
    },
    "max_sensitivity": {
      "type": "string",
      "enum": ["low", "medium", "high", "restricted"]
    },
    "allowed_purposes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["status_check", "dependency_check", "handoff", "manager_update", "request_context"]
      }
    }
  },
  "additionalProperties": false
}
