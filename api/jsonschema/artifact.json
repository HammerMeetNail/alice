{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alice.local/schemas/artifact.json",
  "title": "Artifact",
  "type": "object",
  "required": [
    "type",
    "title",
    "content",
    "source_refs",
    "visibility_mode",
    "sensitivity",
    "confidence"
  ],
  "properties": {
    "type": {
      "type": "string",
      "enum": ["summary", "commitment", "blocker", "status_delta", "request"]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "content": {
      "type": "string",
      "minLength": 1
    },
    "structured_payload": {
      "type": "object"
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["source_system", "source_type", "source_id", "observed_at", "trust_class", "sensitivity"],
        "properties": {
          "source_system": { "type": "string" },
          "source_type": { "type": "string" },
          "source_id": { "type": "string" },
          "source_url": { "type": "string" },
          "observed_at": { "type": "string", "format": "date-time" },
          "trust_class": {
            "type": "string",
            "enum": ["trusted_policy", "structured_system", "untrusted_content"]
          },
          "sensitivity": {
            "type": "string",
            "enum": ["low", "medium", "high", "restricted"]
          }
        }
      }
    },
    "visibility_mode": {
      "type": "string",
      "enum": ["private", "explicit_grants_only", "team_scope", "manager_scope"]
    },
    "sensitivity": {
      "type": "string",
      "enum": ["low", "medium", "high", "restricted"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
