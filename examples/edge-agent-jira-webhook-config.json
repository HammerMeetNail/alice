{
  "agent": {
    "org_slug": "example-corp",
    "owner_email": "jane@example.com",
    "agent_name": "jane-agent",
    "client_type": "edge_agent"
  },
  "server": {
    "base_url": "http://127.0.0.1:8080"
  },
  "connectors": {
    "jira": {
      "actor_email": "jane@example.com",
      "webhook": {
        "enabled": true,
        "listen_addr": "127.0.0.1:8789",
        "secret_env_var": "ALICE_JIRA_WEBHOOK_SECRET",
        "projects": [
          {
            "key": "PAY",
            "project_refs": [
              "payments-api"
            ]
          }
        ]
      }
    }
  },
  "runtime": {
    "state_file": "../.alice/edge-agent-jira-webhook-state.json",
    "query_watch_ids": [],
    "poll_incoming_requests": true
  }
}
