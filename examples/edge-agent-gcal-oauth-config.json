{
  "agent": {
    "org_slug": "example-corp",
    "owner_email": "jane@example.com",
    "agent_name": "jane-agent",
    "client_type": "edge_agent"
  },
  "server": {
    "base_url": "http://127.0.0.1:8080"
  },
  "connectors": {
    "gcal": {
      "enabled": true,
      "calendars": [
        {
          "id": "primary",
          "project_refs": [
            "payments-api"
          ],
          "category": "focus"
        }
      ],
      "oauth": {
        "enabled": true,
        "client_id": "your-google-oauth-client-id",
        "client_secret_env_var": "ALICE_GCAL_CLIENT_SECRET",
        "callback_url": "http://127.0.0.1:8787/oauth/gcal/callback"
      }
    }
  },
  "runtime": {
    "state_file": "../.alice/edge-agent-gcal-oauth-state.json",
    "credentials_file": "../.alice/edge-agent-gcal-credentials.json",
    "credentials_key_env_var": "ALICE_EDGE_CREDENTIAL_KEY",
    "query_watch_ids": [],
    "poll_incoming_requests": true
  }
}
