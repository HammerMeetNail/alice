{
  "agent": {
    "org_slug": "example-corp",
    "owner_email": "jane@example.com",
    "agent_name": "jane-agent",
    "client_type": "edge_agent"
  },
  "server": {
    "base_url": "http://127.0.0.1:8080"
  },
  "connectors": {
    "github": {
      "enabled": true,
      "actor_login": "jane",
      "repositories": [
        {
          "name": "example-corp/payments-api",
          "project_refs": [
            "payments-api"
          ]
        }
      ],
      "oauth": {
        "enabled": true,
        "client_id": "your-github-oauth-client-id",
        "client_secret_env_var": "ALICE_GITHUB_CLIENT_SECRET",
        "callback_url": "http://127.0.0.1:8787/oauth/github/callback"
      }
    }
  },
  "runtime": {
    "state_file": "../.alice/edge-agent-github-oauth-state.json",
    "query_watch_ids": [],
    "poll_incoming_requests": true
  }
}
